{
  "events": [
    {
      "type": "OnSceneLoaded",
      "conditions": [],
      "actions": [
        {
          "type": "ModifyText",
          "object": "difficultyText",
          "modification": "setString",
          "value": "难度: L" + ToString(Variable(Scene.currentDifficulty))
        },
        {
          "type": "ModifyText",
          "object": "starsText",
          "modification": "setString",
          "value": "x " + ToString(GlobalVariable(totalStars))
        },
        {
          "type": "Function",
          "name": "LoadProgress"
        },
        {
          "type": "Function",
          "name": "SetupGame"
        }
      ]
    },
    {
      "type": "Group",
      "name": "初始化游戏",
      "events": [
        {
          "type": "Function",
          "name": "SetupGame",
          "conditions": [],
          "actions": [
            {
              "type": "ModifyText",
              "object": "feedbackText",
              "modification": "setString",
              "value": ""
            },
            {
              "type": "ChangeVisible",
              "object": "rotationHint",
              "visibility": false
            },
            {
              "type": "ChangeVisible",
              "object": "rotationLabel",
              "visibility": false
            },
            {
              "type": "ChangeVisible",
              "object": "旋转指示器",
              "visibility": false
            },
            {
              "type": "ChangeVisible",
              "object": "shapeOutline",
              "visibility": false
            },
            {
              "type": "ChangeVisible",
              "object": "targetShape",
              "visibility": false
            },
            {
              "type": "Conditional",
              "condition": "Variable(Scene.currentDifficulty) == 1",
              "trueActions": [
                {
                  "type": "SetNumberVariable",
                  "variable": "optionCount",
                  "source": "3",
                  "operation": "set"
                },
                {
                  "type": "SetStringVariable",
                  "variable": "shapesPool",
                  "source": "\"圆形;方形;三角形\"",
                  "operation": "set"
                },
                {
                  "type": "SetStringVariable",
                  "variable": "gameMode",
                  "source": "\"match\"",
                  "operation": "set"
                },
                {
                  "type": "SetNumberVariable",
                  "variable": "showOutline",
                  "source": "0",
                  "operation": "set"
                },
                {
                  "type": "ModifyText",
                  "object": "questionLabel",
                  "modification": "setString",
                  "value": "这是什么形状？"
                }
              ],
              "falseActions": []
            },
            {
              "type": "Conditional",
              "condition": "Variable(Scene.currentDifficulty) == 2",
              "trueActions": [
                {
                  "type": "SetNumberVariable",
                  "variable": "optionCount",
                  "source": "4",
                  "operation": "set"
                },
                {
                  "type": "SetStringVariable",
                  "variable": "shapesPool",
                  "source": "\"圆形;方形;三角形;菱形\"",
                  "operation": "set"
                },
                {
                  "type": "SetStringVariable",
                  "variable": "gameMode",
                  "source": "\"outline\"",
                  "operation": "set"
                },
                {
                  "type": "SetNumberVariable",
                  "variable": "showOutline",
                  "source": "1",
                  "operation": "set"
                },
                {
                  "type": "ModifyText",
                  "object": "questionLabel",
                  "modification": "setString",
                  "value": "把形状放入虚线框"
                }
              ],
              "falseActions": []
            },
            {
              "type": "Conditional",
              "condition": "Variable(Scene.currentDifficulty) < 3",
              "trueActions": [],
              "falseActions": [
                {
                  "type": "SetNumberVariable",
                  "variable": "optionCount",
                  "source": "5",
                  "operation": "set"
                },
                {
                  "type": "SetStringVariable",
                  "variable": "shapesPool",
                  "source": "\"圆形;方形;三角形;菱形;椭圆形\"",
                  "operation": "set"
                },
                {
                  "type": "SetStringVariable",
                  "variable": "gameMode",
                  "source": "\"rotate\"",
                  "operation": "set"
                },
                {
                  "type": "SetNumberVariable",
                  "variable": "showOutline",
                  "source": "0",
                  "operation": "set"
                },
                {
                  "type": "ModifyText",
                  "object": "questionLabel",
                  "modification": "setString",
                  "value": "旋转到正确方向！"
                }
              ]
            },
            {
              "type": "Function",
              "name": "GenerateQuestion"
            },
            {
              "type": "Function",
              "name": "PositionShapeButtons"
            },
            {
              "type": "Function",
              "name": "HideUnusedButtons"
            }
          ]
        }
      ]
    },
    {
      "type": "Group",
      "name": "生成题目",
      "events": [
        {
          "type": "Function",
          "name": "GenerateQuestion",
          "conditions": [],
          "actions": [
            {
              "type": "SetStringVariable",
              "variable": "currentCorrectShape",
              "source": "PickRandom(Variable(Scene.shapesPool))",
              "operation": "set"
            },
            {
              "type": "ChangeVisible",
              "object": "questionSprite",
              "visibility": true
            },
            {
              "type": "ChangeSprite",
              "object": "questionSprite",
              "animation": "=Variable(Scene.currentCorrectShape)"
            },
            {
              "type": "ChangeVisible",
              "object": "targetShape",
              "visibility": false
            },
            {
              "type": "Conditional",
              "condition": "Variable(Scene.showOutline) == 1",
              "trueActions": [
                {
                  "type": "ChangeVisible",
                  "object": "shapeOutline",
                  "visibility": true
                },
                {
                  "type": "ChangeSprite",
                  "object": "shapeOutline",
                  "animation": "=Variable(Scene.currentCorrectShape)轮廓"
                },
                {
                  "type": "ChangeXPosition",
                  "object": "shapeOutline",
                  "modification": "set",
                  "value": 570
                },
                {
                  "type": "ChangeYPosition",
                  "object": "shapeOutline",
                  "modification": "set",
                  "value": 140
                },
                {
                  "type": "ChangeVisible",
                  "object": "questionSprite",
                  "visibility": false
                },
                {
                  "type": "ChangeVisible",
                  "object": "targetShape",
                  "visibility": true
                },
                {
                  "type": "ChangeSprite",
                  "object": "targetShape",
                  "animation": "=Variable(Scene.currentCorrectShape)"
                },
                {
                  "type": "ChangeXPosition",
                  "object": "targetShape",
                  "modification": "set",
                  "value": 640
                },
                {
                  "type": "ChangeYPosition",
                  "object": "targetShape",
                  "modification": "set",
                  "value": 150
                }
              ],
              "falseActions": []
            },
            {
              "type": "Conditional",
              "condition": "Variable(Scene.gameMode) == \"rotate\"",
              "trueActions": [
                {
                  "type": "ChangeVisible",
                  "object": "questionSprite",
                  "visibility": false
                },
                {
                  "type": "ChangeVisible",
                  "object": "targetShape",
                  "visibility": true
                },
                {
                  "type": "ChangeSprite",
                  "object": "targetShape",
                  "animation": "=Variable(Scene.currentCorrectShape)"
                },
                {
                  "type": "SetNumberVariable",
                  "variable": "targetRotation",
                  "source": "Random(1, 3)",
                  "operation": "set"
                },
                {
                  "type": "SetNumberVariable",
                  "variable": "currentRotation",
                  "source": "0",
                  "operation": "set"
                },
                {
                  "type": "ChangeRotation",
                  "object": "targetShape",
                  "modification": "set",
                  "value": "Variable(Scene.targetRotation) * 90"
                },
                {
                  "type": "ChangeVisible",
                  "object": "rotationHint",
                  "visibility": true
                },
                {
                  "type": "ChangeVisible",
                  "object": "rotationLabel",
                  "visibility": true
                },
                {
                  "type": "ChangeVisible",
                  "object": "旋转指示器",
                  "visibility": true
                },
                {
                  "type": "ChangeXPosition",
                  "object": "rotationHint",
                  "modification": "set",
                  "value": 1100
                },
                {
                  "type": "ChangeYPosition",
                  "object": "rotationHint",
                  "modification": "set",
                  "value": 100
                },
                {
                  "type": "ChangeXPosition",
                  "object": "rotationLabel",
                  "modification": "set",
                  "value": 1070
                },
                {
                  "type": "ChangeYPosition",
                  "object": "rotationLabel",
                  "modification": "set",
                  "value": 160
                },
                {
                  "type": "ChangeXPosition",
                  "object": "旋转指示器",
                  "modification": "set",
                  "value": 850
                },
                {
                  "type": "ChangeYPosition",
                  "object": "旋转指示器",
                  "modification": "set",
                  "value": 140
                },
                {
                  "type": "ModifyText",
                  "object": "rotationLabel",
                  "modification": "setString",
                  "value": "点击旋转"
                },
                {
                  "type": "ChangeRotation",
                  "object": "targetShape",
                  "modification": "set",
                  "value": "Variable(Scene.currentRotation)"
                }
              ],
              "falseActions": []
            }
          ]
        }
      ]
    },
    {
      "type": "Group",
      "name": "定位形状按钮",
      "events": [
        {
          "type": "Function",
          "name": "PositionShapeButtons",
          "conditions": [],
          "actions": [
            {
              "type": "ChangeXPosition",
              "object": "圆形按钮",
              "modification": "set",
              "value": "(1280 - (Variable(Scene.optionCount) * 120)) / 2"
            },
            {
              "type": "ChangeXPosition",
              "object": "方形按钮",
              "modification": "set",
              "value": "(1280 - (Variable(Scene.optionCount) * 120)) / 2 + 120"
            },
            {
              "type": "ChangeXPosition",
              "object": "三角形按钮",
              "modification": "set",
              "value": "(1280 - (Variable(Scene.optionCount) * 120)) / 2 + 240"
            },
            {
              "type": "ChangeXPosition",
              "object": "菱形按钮",
              "modification": "set",
              "value": "(1280 - (Variable(Scene.optionCount) * 120)) / 2 + 360"
            },
            {
              "type": "ChangeXPosition",
              "object": "椭圆形按钮",
              "modification": "set",
              "value": "(1280 - (Variable(Scene.optionCount) * 120)) / 2 + 480"
            },
            {
              "type": "ChangeYPosition",
              "object": "圆形按钮",
              "modification": "set",
              "value": 450
            },
            {
              "type": "ChangeYPosition",
              "object": "方形按钮",
              "modification": "set",
              "value": 450
            },
            {
              "type": "ChangeYPosition",
              "object": "三角形按钮",
              "modification": "set",
              "value": 450
            },
            {
              "type": "ChangeYPosition",
              "object": "菱形按钮",
              "modification": "set",
              "value": 450
            },
            {
              "type": "ChangeYPosition",
              "object": "椭圆形按钮",
              "modification": "set",
              "value": 450
            },
            {
              "type": "ChangeXPosition",
              "object": "圆形标签",
              "modification": "set",
