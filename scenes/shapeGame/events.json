            {
              "type": "ChangeXPosition",
              "object": "方形标签",
              "modification": "set",
              "value": "(1280 - (Variable(Scene.optionCount) * 120)) / 2 + 140"
            },
            {
              "type": "ChangeXPosition",
              "object": "三角形标签",
              "modification": "set",
              "value": "(1280 - (Variable(Scene.optionCount) * 120)) / 2 + 260"
            },
            {
              "type": "ChangeXPosition",
              "object": "菱形标签",
              "modification": "set",
