            },
            {
              "type": "ChangeXPosition",
              "object": "椭圆形标签",
              "modification": "set",
              "value": "(1280 - (Variable(Scene.optionCount) * 120)) / 2 + 500"
            },
            {
              "type": "ChangeYPosition",
              "object": "圆形标签",
              "modification": "set",
              "value": 540
            },
            {
              "type": "ChangeYPosition",
              "object": "方形标签",
              "modification": "set",
              "value": 540
            },
            {
              "type": "ChangeYPosition",
              "object": "三角形标签",
              "modification": "set",
              "value": 540
            },
            {
              "type": "ChangeYPosition",
              "object": "菱形标签",
              "modification": "set",
              "value": 540
            },
            {
              "type": "ChangeYPosition",
              "object": "椭圆形标签",
              "modification": "set",
              "value": 540
            },
            {
              "type": "ChangeVisible",
              "object": "圆形按钮",
              "visibility": true
            },
            {
              "type": "ChangeVisible",
              "object": "圆形标签",
              "visibility": true
            },
            {
              "type": "ChangeVisible",
              "object": "方形按钮",
              "visibility": true
            },
            {
              "type": "ChangeVisible",
              "object": "方形标签",
              "visibility": true
            },
            {
              "type": "ChangeVisible",
              "object": "三角形按钮",
              "visibility": true
            },
            {
              "type": "ChangeVisible",
              "object": "三角形标签",
              "visibility": true
            },
            {
              "type": "ChangeVisible",
              "object": "菱形按钮",
              "visibility": true
            },
            {
              "type": "ChangeVisible",
              "object": "菱形标签",
              "visibility": true
            },
            {
              "type": "ChangeVisible",
              "object": "椭圆形按钮",
              "visibility": true
            },
            {
              "type": "ChangeVisible",
              "object": "椭圆形标签",
              "visibility": true
            }
          ]
        }
      ]
    },
    {
      "type": "Group",
      "name": "隐藏未使用的按钮",
      "events": [
        {
          "type": "Function",
          "name": "HideUnusedButtons",
          "conditions": [],
          "actions": [
            {
              "type": "Conditional",
              "condition": "Variable(Scene.optionCount) < 5",
              "trueActions": [
                {
                  "type": "ChangeVisible",
                  "object": "椭圆形按钮",
                  "visibility": false
                },
                {
                  "type": "ChangeVisible",
                  "object": "椭圆形标签",
                  "visibility": false
                }
              ],
              "falseActions": []
            },
            {
              "type": "Conditional",
              "condition": "Variable(Scene.optionCount) < 4",
              "trueActions": [
                {
                  "type": "ChangeVisible",
                  "object": "菱形按钮",
                  "visibility": false
                },
                {
                  "type": "ChangeVisible",
                  "object": "菱形标签",
                  "visibility": false
                }
              ],
              "falseActions": []
            },
            {
              "type": "Conditional",
              "condition": "Variable(Scene.optionCount) < 3",
              "trueActions": [
                {
                  "type": "ChangeVisible",
                  "object": "三角形按钮",
                  "visibility": false
                },
                {
                  "type": "ChangeVisible",
                  "object": "三角形标签",
                  "visibility": false
                }
              ],
              "falseActions": []
            }
          ]
        }
      ]
    },
    {
      "type": "Group",
      "name": "旋转目标形状",
      "events": [
        {
          "type": "Onclic",
          "object": "旋转指示器",
          "conditions": [
            {
              "type": "Comparator",
              "object": "gameMode",
              "value": "rotate"
            }
          ],
          "actions": [
            {
              "type": "PlaySound",
              "sound": "click",
              "loop": false,
              "volume": 100,
              "pitch": 1
            },
            {
              "type": "ChangeNumberVariable",
              "variable": "currentRotation",
              "modification": "+",
              "value": 90
            },
            {
              "type": "Conditional",
              "condition": "Variable(Scene.currentRotation) > 270",
              "trueActions": [
                {
                  "type": "SetNumberVariable",
                  "variable": "currentRotation",
                  "source": "0",
                  "operation": "set"
                }
              ],
              "falseActions": []
            },
            {
              "type": "ChangeRotation",
              "object": "targetShape",
              "modification": "set",
              "value": "Variable(Scene.currentRotation)"
            }
          ]
        }
      ]
    },
    {
      "type": "Group",
      "name": "形状按钮点击",
      "events": [
        {
          "type": "Onclic",
          "object": "圆形按钮",
          "conditions": [],
          "actions": [
            {
              "type": "SetStringVariable",
              "variable": "clickedShape",
              "source": "\"圆形\"",
              "operation": "set"
            },
            {
              "type": "Function",
              "name": "HandleShapeButtonClick"
            }
          ]
        },
        {
          "type": "Onclic",
          "object": "方形按钮",
          "conditions": [],
          "actions": [
            {
              "type": "SetStringVariable",
              "variable": "clickedShape",
              "source": "\"方形\"",
              "operation": "set"
            },
            {
              "type": "Function",
              "name": "HandleShapeButtonClick"
            }
          ]
        },
        {
          "type": "Onclic",
          "object": "三角形按钮",
          "conditions": [],
          "actions": [
            {
              "type": "SetStringVariable",
              "variable": "clickedShape",
              "source": "\"三角形\"",
              "operation": "set"
            },
            {
              "type": "Function",
              "name": "HandleShapeButtonClick"
            }
          ]
        },
        {
          "type": "Onclic",
          "object": "菱形按钮",
          "conditions": [],
          "actions": [
            {
              "type": "SetStringVariable",
              "variable": "clickedShape",
              "source": "\"菱形\"",
              "operation": "set"
            },
            {
              "type": "Function",
              "name": "HandleShapeButtonClick"
            }
          ]
        },
        {
          "type": "Onclic",
          "object": "椭圆形按钮",
          "conditions": [],
          "actions": [
            {
              "type": "SetStringVariable",
              "variable": "clickedShape",
              "source": "\"椭圆形\"",
              "operation": "set"
            },
            {
              "type": "Function",
              "name": "HandleShapeButtonClick"
            }
          ]
        }
      ]
    },
    {
      "type": "Group",
      "name": "处理形状按钮点击",
      "events": [
        {
          "type": "Function",
          "name": "HandleShapeButtonClick",
          "conditions": [],
          "actions": [
            {
              "type": "PlaySound",
              "sound": "click",
              "loop": false,
              "volume": 100,
              "pitch": 1
            },
            {
              "type": "Conditional",
              "condition": "Variable(Scene.gameMode) == \"rotate\"",
              "trueActions": [
                {
                  "type": "Conditional",
                  "condition": "Variable(Scene.clickedShape) == Variable(Scene.currentCorrectShape)",
                  "trueActions": [
                    {
                      "type": "Conditional",
                      "condition": "Variable(Scene.currentRotation) == Variable(Scene.targetRotation) * 90",
                      "trueActions": [
                        {
                          "type": "Function",
                          "name": "HandleCorrectAnswer"
                        }
                      ],
                      "falseActions": [
                        {
                          "type": "Function",
                          "name": "HandleWrongRotation"
                        }
                      ]
                    },
                    {
                      "type": "Function",
                      "name": "HandleWrongRotation"
                    }
                  ],
                  "falseActions": [
                    {
                      "type": "Function",
                      "name": "HandleWrongAnswer"
                    }
                  ]
                }
              ],
              "falseActions": [
                {
                  "type": "Conditional",
                  "condition": "Variable(Scene.clickedShape) == Variable(Scene.currentCorrectShape)",
                  "trueActions": [
                    {
                      "type": "Function",
                      "name": "HandleCorrectAnswer"
                    }
                  ],
                  "falseActions": [
                    {
                      "type": "Function",
                      "name": "HandleWrongAnswer"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Group",
      "name": "处理正确答案",
      "events": [
        {
          "type": "Function",
          "name": "HandleCorrectAnswer",
          "conditions": [],
          "actions": [
            {
              "type": "PlaySound",
              "sound": "correct",
              "loop": false,
              "volume": 100,
              "pitch": 1
            },
            {
              "type": "ModifyText",
              "object": "feedbackText",
              "modification": "setString",
              "value": "太棒了！"
            },
            {
              "type": "ChangeGlobalVariable",
              "variable": "totalStars",
              "modification": "+",
              "value": 1
            },
            {
              "type": "ModifyText",
              "object": "starsText",
              "modification": "setString",
              "value": "x " + ToString(GlobalVariable(totalStars))
            },
            {
              "type": "Function",
              "name": "SaveProgress"
            },
            {
              "type": "ChangeNumberVariable",
              "variable": "streakCount",
              "modification": "+",
              "value": 1
            },
            {
              "type": "Conditional",
              "condition": "Variable(Scene.streakCount) >= 2",
              "trueActions": [
                {
                  "type": "Conditional",
                  "condition": "Variable(Scene.currentDifficulty) < 3",
                  "trueActions": [
                    {
                      "type": "ChangeNumberVariable",
                      "variable": "currentDifficulty",
                      "modification": "+",
                      "value": 1
                    }
                  ],
                  "falseActions": []
                },
                {
                  "type": "SetNumberVariable",
                  "variable": "streakCount",
                  "source": "0",
                  "operation": "set"
                },
                {
                  "type": "ModifyText",
                  "object": "difficultyText",
                  "modification": "setString",
                  "value": "难度: L" + ToString(Variable(Scene.currentDifficulty))
                }
              ],
              "falseActions": []
            },
            {
              "type": "Wait",
              "seconds": 1
            },
            {
              "type": "Function",
              "name": "SetupGame"
            }
          ]
        }
      ]
    },
    {
      "type": "Group",
      "name": "处理错误答案",
      "events": [
        {
          "type": "Function",
          "name": "HandleWrongAnswer",
          "conditions": [],
          "actions": [
            {
              "type": "PlaySound",
              "sound": "wrong",
              "loop": false,
              "volume": 100,
              "pitch": 1
            },
            {
              "type": "ModifyText",
              "object": "feedbackText",
              "modification": "setString",
              "value": "没关系，再试一次！"
            },
            {
              "type": "SetNumberVariable",
              "variable": "streakCount",
              "source": "0",
              "operation": "set"
            },
            {
              "type": "Conditional",
              "condition": "Variable(Scene.currentDifficulty) > 1",
              "trueActions": [
                {
                  "type": "ChangeNumberVariable",
                  "variable": "currentDifficulty",
                  "modification": "-",
                  "value": 1
                },
                {
                  "type": "ModifyText",
                  "object": "difficultyText",
                  "modification": "setString",
